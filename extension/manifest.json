{
  "manifest_version": 3,
  "name": "IE Mode",
  "short_name": "IE Mode",
  "description": "Open the current page in Internet Explorer mode with one click. Free.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open in IE Mode"
  },
  "permissions": ["activeTab"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
